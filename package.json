{
  "name": "pandavoice",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.5.0",
    "@types/dompurify": "^3.0.5",
    "better-sqlite3": "^11.9.1",
    "dompurify": "^3.4.11",
    "glob": "^13.0.6",
    "hono": "^4.12.27",
    "lucide-react": "^0.510.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hot-toast": "^2.6.0",
    "react-router": "^7.5.3",
    "zod": "^3.24.3",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "9.25.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "22.14.1",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.5",
    "eslint": "9.25.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "15.15.0",
    "jsdom": "^26.1.0",
    "knip": "^5.51.0",
    "pm2": "^6.0.8",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.0",
    "vite": "^7.1.3",
    "vitest": "^3.1.3"
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "build:client": "vite build",
    "build:server": "node build-server.mjs",
    "build:all": "npm run build:client && npm run build:server",
    "start": "node dist/server/index.js",
    "start:prod": "npm run build:all && node dist/server/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:stop": "pm2 stop pandavoice",
    "pm2:restart": "pm2 restart pandavoice",
    "pm2:logs": "pm2 logs pandavoice",
    "dev": "vite",
    "dev:server": "npm run build:server && node dist/server/index.js",
    "knip": "knip",
    "lint": "eslint .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  }
}
